def print_formatted(number):
    width =len(bin(number)[2:])
    for i in range(1 , number + 1):
        dec_str = str(i)
        oct_str = oct(i)[2:]
        hex_str = oct(i)[2:].upper()
        bin_str = bin(i)[2:]
        print(dec_str.rjust(width), oct_str.rjust(width),hex_str.rjust(width) , bin_str.rjust(width))
if __name__ == '__main__':
    n = int(input())
    print_formatted(n)
