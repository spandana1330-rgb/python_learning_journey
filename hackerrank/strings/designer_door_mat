# Enter your code here. Read input from STDIN. Print output to STDOUT
n =int(input().split()[0])
m = n * 3
pattern = ".|."
for i in range(1 , n , 2):
    row_design = pattern * i
    print(row_design.center(m,'-'))
print("WELCOME".center(m , '-'))
for i in range(n - 2 , 0 , -2):
    row_design = pattern * i
    print(row_design.center(m , '-'))
