def minion_game(string):
    n = len(string)
    Kelvin_score = 0
    Stuart_score = 0
    vowels = "AEIOU"
    for i in range (n):
        if string[i] in vowels:
            Kelvin_score += n - i
        else:
            Stuart_score += n - i
    if Kelvin_score > Stuart_score:
        print(f"Kelvin {Kelvin_score}")
    elif Stuart_score > Kelvin_score:
        print(f"Stuart {Stuart_score}")
    else:
        print("draw")

if __name__ == '__main__':
    s = input()
    minion_game(s)
