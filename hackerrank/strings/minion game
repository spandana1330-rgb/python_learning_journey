def minion_game(string):
    n = len(string)
    Kevin_score = 0
    Stuart_score = 0
    vowels = "AEIOU"
    for i in range (n):
        if string[i] in vowels:
            Kevin_score += n - i
        else:
            Stuart_score += n - i
    if Kevin_score > Stuart_score:
        print(f"Kelvin {Kevin_score}")
    elif Stuart_score > Kevin_score:
        print(f"Stuart {Stuart_score}")
    else:
        print("Draw")

if __name__ == '__main__':
    s = input()
    minion_game(s)
