def merge_the_tools(string, k):
    for i in range(0 , len(string),k):
        substring = string[i : i + k]
        unique_result = ""
        for char in substring:
            if char not in unique_result:
                unique_result += char
        print(unique_result)
if __name__ == '__main__':
    string, k = input(), int(input())
    merge_the_tools(string, k)
